# ============================================
# SERVER CONFIGURATION
# ============================================

PORT=3001
NODE_ENV=development

# ============================================
# AUTHENTICATION
# ============================================
# Must match SCRAPER_API_KEY in Next.js app

API_KEY=generate-a-secure-random-string

# ============================================
# AI PROVIDERS (Video Processing)
# ============================================
# Groq - https://console.groq.com

GROQ_API_KEY=your-groq-api-key

# ============================================
# SUPABASE (Video Job Status Updates)
# ============================================
# Service role key is required to bypass RLS for job status updates
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ============================================
# CLOUDFLARE R2 (Temporary Video Storage)
# ============================================
# Create an R2 bucket and API token at: https://dash.cloudflare.com

R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=contextbridge-videos

# ============================================
# VIDEO PROCESSING PATHS
# ============================================

TUS_UPLOAD_DIR=/tmp/video-processing/uploads
VIDEO_TEMP_DIR=/tmp/video-processing
